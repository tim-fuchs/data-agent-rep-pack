                <mxCell id="upsYfCRB3OX0siGgLaqk-18" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;Support multiple LLM providers&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="409" y="2143" width="184" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="upsYfCRB3OX0siGgLaqk-19" style="rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;endFill=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;verticalAlign=top;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="1" source="nNepE2snTwVHXgM3-cRV-15" target="upsYfCRB3OX0siGgLaqk-18" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="333" y="1978" as="sourcePoint"/>
                        <mxPoint x="46" y="2204" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="upsYfCRB3OX0siGgLaqk-20" value="&lt;div style=&quot;line-height: 150%;&quot;&gt;Ollama&lt;br&gt;(local models)&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" parent="1" vertex="1">
                    <mxGeometry x="374" y="2221" width="93" height="48" as="geometry"/>
                </mxCell>
