                <mxCell id="yuK76GC2vzyNwLmF7uwJ-21" value="&lt;div style=&quot;line-height: 200%;&quot;&gt;Tools:&lt;div&gt;&lt;ul&gt;&lt;li&gt;What tools do users use during offline data analysis?&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" parent="1" vertex="1">
