ANALYZERS=openai,nebius

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini-2026-03-17
OPENAI_BASE_URL=https://api.openai.com/v1/
OPENAI_TIMEOUT_SECONDS=240

NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_MODEL=MiniMaxAI/MiniMax-M2.5
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/
NEBIUS_TIMEOUT_SECONDS=240

SYNTHESIS_API_KEY=your_synthesis_api_key_here
SYNTHESIS_MODEL=gpt-5.4-mini-2026-03-17
SYNTHESIS_BASE_URL=https://api.openai.com/v1/
SYNTHESIS_TIMEOUT_SECONDS=240
